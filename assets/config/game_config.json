{
  "version": "1.0.0",
  "gameName": "重返2010：我的第一桶金",
  "platform": "wechat_minigame",

  "gameplay": {
    "mergeSystem": {
      "gridSize": 7,
      "maxEnergy": 60,
      "energyRegenRate": 20,
      "initialEnergy": 40
    },
    "businessSystem": {
      "maxOrders": 5,
      "orderRefreshInterval": 300,
      "initialShopLevel": 1
    },
    "storySystem": {
      "totalChapters": 3,
      "initialChapter": "chapter_1"
    }
  },

  "economy": {
    "initialCash": 100,
    "initialReputation": 0,
    "initialConnections": 0,
    "maxShopLevel": 6
  },

  "monetization": {
    "ads": {
      "maxDailyAds": 5,
      "energyReward": 30,
      "materialReward": true,
      "doubleReward": true
    },
    "iap": {
      "enabled": false
    }
  },

  "analytics": {
    "enabled": true,
    "tracking": {
      "gameStart": true,
      "mergeComplete": true,
      "orderComplete": true,
      "chapterComplete": true,
      "adComplete": true
    }
  },

  "performance": {
    "targetFPS": 60,
    "maxMemoryMB": 200,
    "enableObjectPool": true,
    "enableCache": true
  }
}