              }
            },
            {
              "type": "item",
              "value": {
                "itemId": "product_2",
                "level": 2,
                "count": 1
              }
            }
          ],
          "rewards": {
            "cash": 200,
            "reputation": 3,
            "connections": 1
          },
          "triggerOnce": true,
          "priority": 8
        },
        {
          "id": "event_ch1_debt_payment",
          "type": "main",
          "title": "第一桶金打脸",
          "description": "合成出第一桶金，当场保住老房子",
          "dialogue": [
            {
              "speaker": "旁白",
              "text": "第三天夜里，你终于攒出了真正的第一桶金...",
              "duration": 2500
            },
            {
              "speaker": "主角",
              "text": "这是第一桶金。债我还，房子我们不卖。",
              "emotion": "proud",
              "duration": 2000
            },
            {
              "speaker": "势利亲戚",
              "text": "你...你真的凑齐了？这么多钱...",
              "emotion": "shocked",
              "duration": 2500
            },
            {
              "speaker": "主角",
              "text": "我说过三天内会还上，现在做到了。",
              "emotion": "satisfied",
              "duration": 2500
            },
            {
              "speaker": "旁白",
              "text": "亲戚第一次对你改变了态度...",
              "duration": 2000
            },
            {
              "speaker": "势利亲戚",
              "text": "既然你这么能干，那我有渠道可以介绍给你...",
              "emotion": "hesitant",
              "duration": 2500
            }
          ],
          "requirements": [
            {
              "type": "event_complete",
              "value": "event_ch1_regular_customers"
            },
            {
              "type": "item",
